# Public base URL used in QR codes
BASE_URL=http://localhost:5000

# Flask
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=false
SECRET_KEY=replace-with-a-random-secret

# Default share expiry (days) — applied when you click Share
DEFAULT_EXPIRY_DAYS=30

# GitHub Releases update check (optional)
# GITHUB_REPO=your-username/QRFileshare
DATABASE_PATH=data/links.db
QR_OUTPUT_DIR=output/qr
GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google_drive/callback

# Dropbox OAuth (optional — or save in app Settings)
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=

# OneDrive / Microsoft (optional — or save in app Settings)
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=
